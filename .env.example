# ═══════════════════════════════════════════════════════════════════════════════
# FRUITOPIA CONFIGURATION
#
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to Git — it's in .gitignore.
#
# ── NAMING CONVENTIONS ────────────────────────────────────────────────────────
# Both naming styles work — use whichever you prefer:
#
#   FIREBASE_API_KEY=...         ← server-side name (works too)
#   VITE_FIREBASE_API_KEY=...    ← Vite frontend name (recommended for Netlify/Vercel)
#
# When running locally with `npm run dev` (tsx server.ts), either style works
# because server.ts loads the .env file and checks both names.
# When deploying to Netlify/Vercel WITHOUT a Node server, you MUST use the
# VITE_ prefix so the values get baked into the frontend build.
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# FIREBASE (REQUIRED)
# Get these from: Firebase Console → Project Settings → General → Your apps
# ───────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:000000000:web:abc123def456
VITE_FIREBASE_DATABASE_ID=(default)

# ───────────────────────────────────────────────────────────────────────────────
# SUPABASE (OPTIONAL ALTERNATIVE BACKEND)
# Use the public anon/publishable key only. Do NOT store admin passwords here.
# ───────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL (OPTIONAL)
# Recommended: Use Gmail + App Password
# Learn more: myaccount.google.com/apppasswords
# ───────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Fruitopia

# ───────────────────────────────────────────────────────────────────────────────
# SMS (OPTIONAL)
# Uses Twilio for SMS notifications
# ───────────────────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ───────────────────────────────────────────────────────────────────────────────
# PAYMENT GATEWAYS (OPTIONAL)
# Configure via InstallWizard GUI or here
# ───────────────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_
PAYPAL_CLIENT_ID=
RAZORPAY_KEY_ID=
SSLCOMMERZ_STORE_ID=
BKASH_APP_KEY=
NAGAD_MERCHANT_ID=

# ───────────────────────────────────────────────────────────────────────────────
# PLATFORM & SERVER
# ───────────────────────────────────────────────────────────────────────────────

# ───────────────────────────────────────────────────────────────────────────────
# RECAPTCHA (OPTIONAL — server-side verification)
# Get from: https://www.google.com/recaptcha/admin → Your site → Secret Key
# The Site Key goes in Admin Panel → CMS Settings → reCAPTCHA.
# The Secret Key stays here on the server — never expose it to the client.
# ───────────────────────────────────────────────────────────────────────────────

RECAPTCHA_SECRET_KEY=

NODE_ENV=development
PORT=3005
VITE_APP_URL=http://localhost:3005
